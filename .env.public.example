# Copy file ini jadi .env.public lalu isi nilainya.
# URL publik Supabase gateway via Cloudflare Tunnel (HTTPS wajib).
PUBLIC_SUPABASE_URL="https://supabase-gudang.example.com"

# Publishable key dari `npx supabase status` (bagian Publishable).
PUBLIC_SUPABASE_ANON_KEY="sb_publishable_xxx"

# Tunnel token dari Cloudflare Zero Trust > Networks > Tunnels > pilih tunnel > Run tunnel.
# Format biasanya dimulai dengan eyJh...
CLOUDFLARE_TUNNEL_TOKEN=""
